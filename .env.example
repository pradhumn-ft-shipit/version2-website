# Cloudflare Pages Functions read .dev.vars locally — copy this file to
# .dev.vars (not .env) and fill in values.
#
# In production, set these in Cloudflare dashboard → Pages → your project →
# Settings → Environment Variables.

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/XXX/XXX

# Loops transactional API key for lead-notification emails. Optional locally —
# if unset, the form still works and posts to Slack, but no emails are sent.
LOOPS_API_KEY=

# --- Front-end build var (Vite) -------------------------------------------
# Absolute URL of the contact API. Production (Render) sets this to the
# Cloudflare worker so the cross-origin form POST hits *.pages.dev. Leave it
# UNSET locally so the form falls back to the relative /api/contact and works
# under `npm run dev:cf` (wrangler). Set in Render via render.yaml.
# VITE_CONTACT_API_URL=https://version2-website.pages.dev/api/contact
